    "configuration": {
      "title": "C# Project Manager",
      "properties": {
        "csharpsolution.buildTool": {
          "type": "string",
          "enum": ["auto", "dotnet", "msbuild"],
          "default": "auto",
          "description": "构建工具：auto 按项目类型选择（传统项目优先 MSBuild），或强制指定"
        },
        "csharpsolution.msbuildPath": {
          "type": "string",
          "default": "",
          "description": "msbuild.exe 完整路径（留空则通过 vswhere/PATH 自动探测）"
        },
        "csharpsolution.vcs": {
          "type": "string",
          "enum": [
            "git",
            "svn",
            "none"
          ],
          "default": "git",
          "description": "版本控制系统（SVN 需要命令行工具）"
        },
        "csharpsolution.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "额外的排除 glob 模式（与默认的 node_modules/bin/obj 合并）"
        },
        "csharpsolution.defaultNamespace": {
          "type": "string",
          "default": "",
          "description": "默认根命名空间（留空则使用项目名称作为命名空间）"
        },
        "csharpsolution.renameSyncCode": {
          "type": "boolean",
          "default": true,
          "description": "重命名文件时自动更新 class/namespace 声明"
        },
        "csharpsolution.tortoiseSvnPath": {
          "type": "string",
          "default": "",
          "description": "TortoiseSVN TortoiseProc.exe 完整路径（留空则自动探测）"
        },
        "csharpsolution.tortoiseGitPath": {
          "type": "string",
          "default": "",
          "description": "TortoiseGit TortoiseGitProc.exe 完整路径（留空则自动探测）"
        }
      }
    }
