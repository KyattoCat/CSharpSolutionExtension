    "configuration": {
      "title": "%category%",
      "properties": {
        "csharpsolution.buildTool": {
          "type": "string",
          "enum": ["auto", "dotnet", "msbuild"],
          "default": "auto",
          "description": "%config.buildTool%"
        },
        "csharpsolution.msbuildPath": {
          "type": "string",
          "default": "",
          "description": "%config.msbuildPath%"
        },
        "csharpsolution.vcs": {
          "type": "string",
          "enum": [
            "git",
            "svn",
            "none"
          ],
          "default": "git",
          "description": "%config.vcs%"
        },
        "csharpsolution.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.excludePatterns%"
        },
        "csharpsolution.defaultNamespace": {
          "type": "string",
          "default": "",
          "description": "%config.defaultNamespace%"
        },
        "csharpsolution.renameSyncCode": {
          "type": "boolean",
          "default": true,
          "description": "%config.renameSyncCode%"
        },
        "csharpsolution.tortoiseSvnPath": {
          "type": "string",
          "default": "",
          "description": "%config.tortoiseSvnPath%"
        },
        "csharpsolution.tortoiseGitPath": {
          "type": "string",
          "default": "",
          "description": "%config.tortoiseGitPath%"
        }
      }
    }
