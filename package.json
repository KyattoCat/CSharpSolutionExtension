{
  "name": "csharpsolution",
  "displayName": "CSharpSolution",
  "description": "管理传统 C# 项目（非 SDK 风格）的 VS Code 扩展，支持项目浏览、添加类、删除文件并自动维护 .csproj",
  "publisher": "kyattocat",
  "repository": { "url": "https://github.com/KyattoCat/CSharpSolutionExtension" },
  "version": "1.3.3",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.csproj"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "csharpsolution",
          "title": "C# 项目管理",
          "icon": "$(folder-library)"
        }
      ]
    },
    "views": {
      "csharpsolution": [
        {
          "id": "csharpsolution-projects",
          "name": "项目管理"
        }
      ]
    },
    "commands": [
      {
        "command": "csharpsolution.refresh",
        "title": "刷新项目管理",
        "icon": "$(refresh)"
      },
      {
        "command": "csharpsolution.addClass",
        "title": "添加类..."
      },
      {
        "command": "csharpsolution.deleteFile",
        "title": "删除"
      },
      {
        "command": "csharpsolution.addExistingFile",
        "title": "添加现有文件..."
      },
      {
        "command": "csharpsolution.removePackage",
        "title": "移除包"
      },
      {
        "command": "csharpsolution.renameFile",
        "title": "重命名"
      },
      {
        "command": "csharpsolution.build",
        "title": "生成"
      },
      {
        "command": "csharpsolution.clean",
        "title": "清理"
      },
      {
        "command": "csharpsolution.rebuild",
        "title": "重新生成"
      },
      {
        "command": "csharpsolution.addNewProject",
        "title": "添加新项目..."
      },
      {
        "command": "csharpsolution.addExistingProject",
        "title": "添加已有项目..."
      },
      {
        "command": "csharpsolution.removeProjectFromSolution",
        "title": "从解决方案移除"
      },
      {
        "command": "csharpsolution.revealInExplorer",
        "title": "在文件资源管理器中显示"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "csharpsolution.refresh",
          "when": "view == csharpsolution-projects",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "csharpsolution.addClass",
          "when": "view == csharpsolution-projects && viewItem == project",
          "group": "navigation@1"
        },
        {
          "command": "csharpsolution.addExistingFile",
          "when": "view == csharpsolution-projects && viewItem == project",
          "group": "navigation@2"
        },
        {
          "command": "csharpsolution.addClass",
          "when": "view == csharpsolution-projects && viewItem == dirFolder",
          "group": "navigation@1"
        },
        {
          "command": "csharpsolution.deleteFile",
          "when": "view == csharpsolution-projects && viewItem == file",
          "group": "navigation@2"
        },
        {
          "command": "csharpsolution.removePackage",
          "when": "view == csharpsolution-projects && viewItem == package",
          "group": "navigation@1"
        },
        {
          "command": "csharpsolution.renameFile",
          "when": "view == csharpsolution-projects && viewItem == file",
          "group": "navigation@1"
        },
        {
          "command": "csharpsolution.build",
          "when": "view == csharpsolution-projects && viewItem == project",
          "group": "group2@1"
        },
        {
          "command": "csharpsolution.clean",
          "when": "view == csharpsolution-projects && viewItem == project",
          "group": "group2@2"
        },
        {
          "command": "csharpsolution.rebuild",
          "when": "view == csharpsolution-projects && viewItem == project",
          "group": "group2@3"
        },
        {
          "command": "csharpsolution.build",
          "when": "view == csharpsolution-projects && viewItem == solution",
          "group": "group2@1"
        },
        {
          "command": "csharpsolution.clean",
          "when": "view == csharpsolution-projects && viewItem == solution",
          "group": "group2@2"
        },
        {
          "command": "csharpsolution.rebuild",
          "when": "view == csharpsolution-projects && viewItem == solution",
          "group": "group2@3"
        },
        {
          "command": "csharpsolution.addNewProject",
          "when": "view == csharpsolution-projects && viewItem == solution",
          "group": "group1@1"
        },
        {
          "command": "csharpsolution.addExistingProject",
          "when": "view == csharpsolution-projects && viewItem == solution",
          "group": "group1@2"
        },
        {
          "command": "csharpsolution.removeProjectFromSolution",
          "when": "view == csharpsolution-projects && viewItem == solutionProject",
          "group": "group3@1"
        },
        {
          "command": "csharpsolution.build",
          "when": "view == csharpsolution-projects && viewItem == solutionProject",
          "group": "group2@1"
        },
        {
          "command": "csharpsolution.clean",
          "when": "view == csharpsolution-projects && viewItem == solutionProject",
          "group": "group2@2"
        },
        {
          "command": "csharpsolution.rebuild",
          "when": "view == csharpsolution-projects && viewItem == solutionProject",
          "group": "group2@3"
        },
        {
          "command": "csharpsolution.revealInExplorer",
          "when": "view == csharpsolution-projects && viewItem == project",
          "group": "group4@1"
        },
        {
          "command": "csharpsolution.revealInExplorer",
          "when": "view == csharpsolution-projects && viewItem == solutionProject",
          "group": "group4@1"
        },
        {
          "command": "csharpsolution.revealInExplorer",
          "when": "view == csharpsolution-projects && viewItem == solution",
          "group": "group4@1"
        },
        {
          "command": "csharpsolution.revealInExplorer",
          "when": "view == csharpsolution-projects && viewItem == file",
          "group": "group4@1"
        },
        {
          "command": "csharpsolution.revealInExplorer",
          "when": "view == csharpsolution-projects && viewItem == dirFolder",
          "group": "group4@1"
        }
      ]
    },
    "configuration": {
      "title": "C# Project Manager",
      "properties": {
        "csharpsolution.vcs": {
          "type": "string",
          "enum": ["git", "svn", "none"],
          "default": "git",
          "description": "版本控制系统（SVN 需要命令行工具）"
        },
        "csharpsolution.excludePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "额外的排除 glob 模式（与默认的 node_modules/bin/obj 合并）"
        },
        "csharpsolution.defaultNamespace": {
          "type": "string",
          "default": "",
          "description": "默认根命名空间（留空则使用项目名称作为命名空间）"
        },
        "csharpsolution.renameSyncCode": {
          "type": "boolean",
          "default": true,
          "description": "重命名文件时自动更新 class/namespace 声明"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~18.19.130",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}
