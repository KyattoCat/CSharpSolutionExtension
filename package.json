{
  "name": "csharpsolution",
  "displayName": "CSharpSolution",
  "description": "C# 项目管理扩展，支持传统/SDK 项目浏览、文件增删改、构建配置切换、诊断装饰及 TortoiseSVN/Git 集成",
  "publisher": "kyattocat",
  "repository": {
    "url": "https://github.com/KyattoCat/CSharpSolutionExtension"
  },
  "version": "1.9.1",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.csproj"
  ],
  "main": "./out/extension.js",
